# Cloudflare Pages auto-runs `npm install` when it sees package.json.
# Our only dependency is @playwright/test (devDependency, ~150MB with
# browser drivers) — that node_modules tree tripped the per-asset
# 25MB Pages limit and failed deploy.
#
# We have ZERO production dependencies (the game ships as static
# HTML/CSS/JS), so `production=true` means `npm install` becomes a
# no-op on Pages. Local `npm install` for tests still works because
# you'll explicitly run `npm install --include=dev` or just `npm i`
# in your dev shell where `production=true` is overridden by --include=dev.
production=true
